# Banco de dados
# Dev (SQLite): file:./dev.db
# Prod (Postgres): postgresql://user:pass@host:5432/dbname?schema=public
DATABASE_URL="file:./dev.db"

# Segredo usado para assinar o JWT das sessões
JWT_SECRET="defina-um-segredo-forte"

# Janela máxima de agendamento à frente (em meses)
MAX_BOOKING_MONTHS=3
