# ── Banco de dados (PostgreSQL — recomendado Neon) ──────────────────────────
# DATABASE_URL: conexão "pooled" (com -pooler no host). Usada pela aplicação.
# DIRECT_URL:   conexão direta (sem -pooler). Usada por `prisma migrate`.
# Pegue as duas no painel do Neon (Connection Details).
DATABASE_URL="postgresql://USUARIO:SENHA@ep-xxxx-pooler.REGIAO.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USUARIO:SENHA@ep-xxxx.REGIAO.aws.neon.tech/neondb?sslmode=require"

# ── Segurança ───────────────────────────────────────────────────────────────
# Segredo para assinar o JWT das sessões. Gere um valor forte e único.
JWT_SECRET="defina-um-segredo-forte-e-aleatorio"

# ── Regras de negócio ───────────────────────────────────────────────────────
# Janela máxima de agendamento à frente (em meses)
MAX_BOOKING_MONTHS=3
